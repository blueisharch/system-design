    {
      "id": "cascadeHdr",
      "type": "text",
      "x": 30,
      "y": 288,
      "width": 320,
      "height": 20,
      "text": "Without Circuit Breaker → Cascade Failure",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "center",
      "strokeColor": "#c92a2a",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,
      "opacity": 100
    },
    {
      "id": "cascadeBody",
      "type": "text",
      "x": 30,
      "y": 312,
      "width": 320,
      "height": 110,
      "text": "Service A → Service B → Service C 💥 DOWN\n\nAll threads in A hang waiting for B timeout\nAll threads in B hang waiting for C timeout\nThread pools exhaust → A goes down too\n→ Full cascade failure 🔥\n\nWith CB: A detects C is down, fails fast,\nreturns cached/default. A stays healthy.",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#c92a2a",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,
      "opacity": 100
    },
    {
      "id": "fallbackBox",
      "type": "rectangle",
      "x": 380,
      "y": 280,
      "width": 340,
      "height": 150,
      "strokeColor": "#1971c2",
      "backgroundColor": "#e7f5ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "roundness": { "type": 3 }
    },
    {
      "id": "fallbackHdr",
      "type": "text",
      "x": 390,
      "y": 288,
      "width": 320,
      "height": 20,
      "text": "Fallback Strategies",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "center",
      "strokeColor": "#1971c2",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,
      "opacity": 100
    },
    {
      "id": "fallbackBody",
      "type": "text",
      "x": 390,
      "y": 312,
      "width": 320,
      "height": 110,
      "text": "Cached response  → last known good data\nDefault value    → empty array, 0 count\nStatic response  → maintenance message\nQueue request    → process later async\nRedirect         → static maintenance page\n\nLibraries: Resilience4j (Java), opossum (Node),\npolly (.NET), gobreaker (Go), Istio (mesh)",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#1971c2",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,
      "opacity": 100
    }
  ],

      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "roundness": { "type": 3 }
    },
    {
      "id": "openHdr",
      "type": "text",
      "x": 280,
      "y": 68,
      "width": 180,
      "height": 24,
      "text": "🔴 OPEN",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "center",
      "strokeColor": "#c92a2a",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,
      "opacity": 100
    },
    {
      "id": "openBody",
      "type": "text",
      "x": 280,
      "y": 96,
      "width": 180,
      "height": 88,
      "text": "Service is DOWN\nAll requests FAIL FAST\nNo network call made\nReturn fallback/cache\nAfter timeout (e.g. 60s)\n→ move to HALF-OPEN",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#c92a2a",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,
      "opacity": 100
    },
    {

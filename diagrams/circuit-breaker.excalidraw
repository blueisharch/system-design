      "textAlign": "center",
      "strokeColor": "#e67700",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,
      "opacity": 100
    },
    {
      "id": "halfBody",
      "type": "text",
      "x": 530,
      "y": 96,
      "width": 180,
      "height": 88,
      "text": "Testing recovery\nLet probe requests thru\nSuccess → CLOSED ✅\n  (service recovered!)\nFailure → OPEN ❌\n  (still down, wait more)",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#e67700",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,

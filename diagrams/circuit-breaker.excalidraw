    {
      "id": "closedBody",
      "type": "text",
      "x": 30,
      "y": 96,
      "width": 180,
      "height": 88,
      "text": "Normal operation\nRequests flow through\nTrack failures:\n  failures < threshold\n→ stay CLOSED\n  failures ≥ threshold\n→ trip to OPEN",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#2f9e44",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,
      "opacity": 100
    },

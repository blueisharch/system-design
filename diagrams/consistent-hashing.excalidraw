    },
    {
      "id": "chbody",
      "type": "text",
      "x": 570,
      "y": 285,
      "width": 200,
      "height": 110,
      "text": "Ring: keys + servers\nmapped to same space\n\nAdd/remove server:\nOnly ~1/N keys move!\n\nVirtual Nodes: 100+\npoints per server\n-> even distribution",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#1a7838",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,

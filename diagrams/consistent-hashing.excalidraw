      "x": 570,
      "y": 88,
      "width": 200,
      "height": 25,
      "text": "Modulo Hashing Problem",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "center",
      "strokeColor": "#c92a2a",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,
      "opacity": 100
    },
    {
      "id": "modbody",
      "type": "text",
      "x": 570,
      "y": 115,
      "width": 200,
      "height": 110,
      "text": "hash(key) % N\n\nAdd/remove server:\nN changes -> ~100% of\nkeys get remapped!\n\n= Cache miss storm\n= DB hammered\n= Outage risk",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#c92a2a",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,
      "opacity": 100
    },

    },
    {
      "id": "ctbody",
      "type": "text",
      "x": 370,
      "y": 100,
      "width": 280,
      "height": 138,
      "text": "[App A] [App B] [App C]\n     [Container Runtime]\n       [Host OS Kernel]   <- shared!\n          [Hardware]\n\nSize: 10-100 MB per container\nStart time: milliseconds\nIsolated process, shared kernel",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#1a7838",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,
      "opacity": 100
    },
    {
      "id": "docker",
      "type": "rectangle",
      "x": 20,
      "y": 270,
      "width": 300,
      "height": 180,
      "strokeColor": "#1971c2",
      "backgroundColor": "#e7f5ff",
      "fillStyle": "solid",
      "strokeWidth": 2,

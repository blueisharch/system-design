    },
    {
      "id": "spotHdr",
      "type": "text",
      "x": 390,
      "y": 218,
      "width": 320,
      "height": 20,
      "text": "⚡ Spot / Preemptible Instances",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "center",
      "strokeColor": "#862e9c",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,
      "opacity": 100
    },
    {
      "id": "spotBody",
      "type": "text",
      "x": 390,
      "y": 243,
      "width": 320,
      "height": 110,
      "text": "Up to 90% cheaper than on-demand\nCloud can reclaim with 2-min notice\n\n✅ USE FOR:\n  Batch jobs, ML training\n  Stateless workers, image processing\n  CI/CD build agents\n\n❌ NEVER USE FOR:\n  Databases (data loss risk)\n  API servers (traffic drops)\n  Stateful services",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#862e9c",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,
      "opacity": 100
    }

    {
      "id": "useCasesHdr",
      "type": "text",
      "x": 30,
      "y": 208,
      "width": 310,
      "height": 20,
      "text": "✅ Run at the Edge",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "center",
      "strokeColor": "#e67700",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,
      "opacity": 100
    },
    {
      "id": "useCasesBody",
      "type": "text",
      "x": 30,
      "y": 232,
      "width": 310,
      "height": 132,
      "text": "🔑 Auth validation (check JWT, reject 401s)\n   → Block before hitting origin servers\n\n🌍 Geo-based redirects\n   → country header → redirect to local domain\n\n🧪 A/B testing\n   → rewrite URL based on cookie variant\n\n🤖 Bot detection\n   → block bad IPs, verify user-agents\n\n🔒 Security headers\n   → inject CSP, HSTS on all responses",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#e67700",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,
      "opacity": 100
    },

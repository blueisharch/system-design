    {
      "id": "tflow",
      "type": "text",
      "x": 420,
      "y": 388,
      "width": 340,
      "height": 92,
      "text": "Redirect Flow:\n1. GET /:code -> URL Service\n2. Check Redis (HIT -> 302 in <1ms)\n3. MISS -> query PostgreSQL\n4. Store in Redis with TTL=24h\n5. Return 302 (not 301 -- need analytics+expiry!)",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#1a7838",
      "verticalAlign": "middle",

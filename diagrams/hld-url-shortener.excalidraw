    {
      "id": "tbase62",
      "type": "text",
      "x": 30,
      "y": 388,
      "width": 350,
      "height": 92,
      "text": "Short Code Generation (Base62):\ncharset = [0-9 a-z A-Z] = 62 chars\n7 chars = 62^7 = 3.5 trillion unique codes\n\nAuto-increment DB ID -> Base62(ID) = short code\nEx: ID 123456789 -> Base62 -> '8M0kX'",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#1864ab",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,
      "opacity": 100
    },

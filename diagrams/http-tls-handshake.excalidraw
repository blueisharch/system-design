      "x": 30,
      "y": 422,
      "width": 360,
      "height": 72,
      "text": "HTTP Versions:\nHTTP/1.1: keep-alive, sequential requests\nHTTP/2: multiplexing (parallel on 1 conn), header compression\nHTTP/3: QUIC/UDP, 0-RTT, faster mobile connections",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#6a1e9c",
      "verticalAlign": "middle",

    {
      "id": "tvis",
      "type": "text",
      "x": 30,
      "y": 285,
      "width": 750,
      "height": 75,
      "text": "Visibility Timeout: Consumer pulls msg -> msg HIDDEN for 30s\n  Consumer succeeds -> deletes msg -> gone forever\n  Consumer CRASHES -> 30s later msg REAPPEARS -> another worker picks it up (at-least-once delivery!)\nIMPORTANT: consumers MUST be idempotent (check if orderId already processed before acting)",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#1864ab",
      "verticalAlign": "middle",
      "groupIds": [],
      "roundness": null,
      "opacity": 100
    },

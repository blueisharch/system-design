      }
    },
    {
      "id": "tdlq",
      "type": "text",
      "x": 30,
      "y": 380,
      "width": 750,
      "height": 75,
      "text": "Dead Letter Queue (DLQ): Message fails 3 times -> moved to DLQ\nOps team inspects DLQ -> fix bug -> redrive messages back to main queue\nNever lose a message! DLQ is your safety net for debugging production failures.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#c92a2a",
      "verticalAlign": "middle",
